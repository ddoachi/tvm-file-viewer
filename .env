# Electron Configuration
# Modify these values for your office environment

# Path to the electron binary
# Default: ./node_modules/electron/dist/electron
# Office example: /opt/electron/electron or C:\electron\electron.exe
ELECTRON_PATH=./node_modules/electron/dist/electron

# Disable sandbox (required on some Linux environments)
ELECTRON_DISABLE_SANDBOX=1

# Node environment (development | production)
NODE_ENV=production

# Editor path for opening files (default: gvim)
# Examples: /usr/bin/gvim, /opt/vim/bin/gvim, vim, code
EDITOR_PATH=gvim
